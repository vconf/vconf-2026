{
  "name": "vconf-2026",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "prepare": "husky install",
    "commit": "cz",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "changelog:first": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "version": "pnpm run changelog && git add CHANGELOG.md",
    "release": "pnpm run changelog && git add CHANGELOG.md && git commit -m 'docs: update changelog' && git push",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@tresjs/nuxt": "^5.6.1",
    "gsap": "^3.13.0",
    "lenis": "^1.3.8",
    "lottie-web": "^5.13.0",
    "reka-ui": "^2.4.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.2.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@nuxt/fonts": "0.11.4",
    "@nuxt/icon": "^1.15.0",
    "@nuxt/image": "^1.10.0",
    "@nuxt/scripts": "0.11.10",
    "@nuxtjs/color-mode": "4.0.0",
    "@nuxtjs/seo": "^3.1.0",
    "@nuxtjs/storybook": "9.0.1",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commitizen": "^4.3.1",
    "conventional-changelog-angular": "^8.0.0",
    "conventional-changelog-cli": "^5.0.0",
    "cssnano": "^7.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.33.0",
    "eslint-plugin-storybook": "^0.8.0",
    "eslint-plugin-tailwindcss": "^3.17.5",
    "husky": "^8.0.0",
    "lint-staged": "^16.1.5",
    "nuxt": "^3.18.1",
    "nuxt-typed-router": "4.0.1",
    "prettier": "^3.6.2",
    "storybook": "9.1.20",
    "tailwind-clip-path": "^1.0.0",
    "tailwind-merge": "^2.5.5",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^6.0.0",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix"
    ],
    "*.{css,scss,vue}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
